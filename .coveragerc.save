[run]
source = triples_sigfast

[report]
exclude_lines =
    pragma: no cover
    raise ImportError
    raise NotImplementedError
    raise ValueError.*No backend
    def __exit__
    if TYPE_CHECKING
    except ImportError
    pragma: no cover
    import plotly
    from plotly
    if plotly
    except ImportError
    def _is_notebook
    def _plotly_available
    def _hex_to_
